#: app/html/menus/dashboard/tabs/changelog.php:622
msgid "[PRO] Added a shortcode for an independent \"Add Listing\" form."
msgstr ""
"[PRO] Es wurde ein Shortcode für ein unabhängiges Formular \"Eintrag "
"hinzufügen\" hinzugefügt."

#: app/html/menus/dashboard/tabs/changelog.php:625
msgid "[PRO] Added responsive view support for the \"Side by Side\" skin."
msgstr ""
"[PRO] Unterstützung der responsiven Ansicht für den Skin \"Seite an Seite\" "
"hinzugefügt."

#: app/html/menus/dashboard/tabs/changelog.php:628
msgid "Introduced support for listing excerpts."
msgstr "Unterstützung für die Auflistung von Auszügen wurde eingeführt."

#: app/html/menus/dashboard/tabs/changelog.php:631
msgid "Enabled featured image display in style 3 of single listing."
msgstr ""
